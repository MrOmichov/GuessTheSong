<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.mromichov.guessthesong.ui.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="gameTitle" text="Guess the Piece of Music">
      <font>
         <Font name="System Bold" size="24.0" />
      </font></Label>
   <TextField fx:id="guessField" promptText="Enter your guess" />
   <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="60.0">
      <children>
          <Button fx:id="playButton" onAction="#onPlayButtonClick" text="Play!" />
         <Button fx:id="guessButton" mnemonicParsing="false" onAction="#onGuessButtonClick" text="Button" />
      </children>
   </HBox>
</VBox>
